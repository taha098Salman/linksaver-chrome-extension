{
  "manifest_version": 3,
  "name": "LinkSaver",
  "version": "1.0",
  "description": "Save useful links while browsing",
  "action": {
    "default_popup": "index.html",
    "default_icon": "icon.png"
  },
  "permissions": ["tabs"],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}